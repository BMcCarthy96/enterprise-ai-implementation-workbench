# Copy to .env and adjust. Defaults target local Docker + LocalStack.

# --- Database (RDS PostgreSQL in production) ---
DATABASE_URL=postgres://workbench:workbench@localhost:5433/workbench

# --- Auth ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string

# --- AWS ---
# In production, drop AWS_ENDPOINT_URL and rely on IAM roles / real credentials.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

S3_BUCKET=workbench-documents
JOBS_QUEUE_URL=http://localhost:4566/000000000000/workbench-jobs

# --- AI ---
# "mock" runs fully offline with deterministic output; "bedrock" calls AWS Bedrock.
AI_PROVIDER=mock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# --- Misc ---
LOG_LEVEL=info
